{
  "name": "screenshot-agent",
  "version": "0.1.0",
  "description": "CLI that takes a screenshot and spawns a Claude Code agent to fix the issue in a target repo",
  "type": "module",
  "bin": {
    "screenshot-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts"
  },
  "author": "jschell12",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
